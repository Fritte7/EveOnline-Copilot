<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.EveOnlineCopilot" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/eve_primary</item>
        <item name="colorPrimaryVariant">@color/eve_primary_variant</item>
        <item name="colorOnPrimary">@color/eve_on_primary</item>

        <!-- Secondary (can reuse primary for terminal aesthetic) -->
        <item name="colorSecondary">@color/eve_primary</item>
        <item name="colorSecondaryVariant">@color/eve_primary_variant</item>
        <item name="colorOnSecondary">@color/eve_on_primary</item>

        <!-- Window / background -->
        <item name="android:windowBackground">@color/eve_bg</item>
        <item name="android:colorBackground">@color/eve_bg</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/eve_bg</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar (optional but nice) -->
        <item name="android:navigationBarColor">@color/eve_bg</item>

        <!-- Remove action bar (Compose handles top bars) -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
